CONTAINER_NAME=chrome-sandbox
PUID=1000
PGID=1000
TZ=Etc/UTC

WEB_HTTP_PORT=3000
WEB_HTTPS_PORT=3001

CDP_PROXY_PORT=9223
CDP_PROXY_BIND_ADDRESS=0.0.0.0

CHROME_DEBUG_ADDRESS=127.0.0.1
CHROME_DEBUG_PORT=9222
CHROME_USER_DATA_DIR=/config/chrome-debug-profile
CHROME_SESSION_RESTORE_ENABLED=true

CHROME_SHM_SIZE=1gb

# Extra Chrome flags appended to the generated remote-debugging flags.
EXTRA_CHROME_CLI=
